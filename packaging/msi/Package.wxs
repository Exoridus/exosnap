<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <!--
    ExoSnap MSI Installer
    =====================
    Package identity: Codexo.ExoSnap
    UpgradeCode: 8988DAFC-3AE4-4788-BA6D-62E3F73C7A7D (permanent — ADR 0034, NEVER CHANGE)
    ProductCode is auto-generated per build (*).

    File list is NOT hand-maintained here. The release script
    (scripts/build-release-artifacts.ps1) generates a companion WXS fragment
    (_harvest.wxs) from the pruned CMake install staging tree and passes both
    files to `wix build`. The fragment defines:
      - the subdirectory hierarchy (plugins/, licenses/, …) under INSTALLFOLDER
      - one <Component>/<File> per staged file
      - a master <ComponentGroup Id="StagingFiles"> that this Feature references

    This means the MSI and the portable ZIP are always derived from the same
    source (the cmake install staging tree), so FFmpeg DLLs, dxcompiler.dll,
    dxil.dll, and any future runtime DLL added by a cmake install rule are
    automatically included in both artifacts — no per-file maintenance needed.

    The build script also runs a post-build MSI content assertion (msiexec /a
    extraction) to catch any drift before a release can ship.

    User data is NOT installed or removed by this MSI.
  -->

  <Package Name="ExoSnap"
           Manufacturer="Codexo"
           Version="$(var.ProductVersion)"
           UpgradeCode="8988DAFC-3AE4-4788-BA6D-62E3F73C7A7D"
           Scope="perMachine"
           Language="1033"
           Codepage="1252">

    <MajorUpgrade DowngradeErrorMessage="A newer version of ExoSnap is already installed."
                  AllowSameVersionUpgrades="yes" />

    <Media Id="1" Cabinet="exosnap.cab" EmbedCab="yes" />

    <!-- Install-root directory skeleton.
         Subdirectories (plugins/, licenses/, …) are defined by _harvest.wxs. -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="ManufacturerFolder" Name="Codexo">
        <Directory Id="INSTALLFOLDER" Name="ExoSnap" />
      </Directory>
    </StandardDirectory>

    <!-- Start Menu shortcut (all-users, per-machine) — stable Guid per ADR 0034 -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Component Id="StartMenuShortcut" Guid="{C1D2E3F4-A5B6-7890-CDEF-1234567890AB}" KeyPath="yes">
        <Shortcut Id="StartMenuExoSnap"
                  Name="ExoSnap"
                  Description="Windows-native recording application"
                  Target="[INSTALLFOLDER]exosnap.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKLM"
                       Key="Software\Codexo\ExoSnap"
                       Name="installed"
                       Value="1"
                       Type="integer" />
      </Component>
    </StandardDirectory>

    <!-- ARP (Add/Remove Programs) metadata -->
    <Property Id="ARPCOMMENTS" Value="Windows-native diagnostics-first recording application" />
    <Property Id="ARPCONTACT" Value="https://github.com/Exoridus/exosnap" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/Exoridus/exosnap" />
    <Property Id="ARPHELPLINK" Value="https://github.com/Exoridus/exosnap/issues" />
    <Property Id="ARPNOMODIFY" Value="1" />
    <Property Id="ARPNOREPAIR" Value="0" />

    <!-- Feature tree.
         StagingFiles is the master ComponentGroup defined in _harvest.wxs;
         it aggregates every file in the pruned cmake staging tree. -->
    <Feature Id="MainFeature"
             Title="ExoSnap"
             Level="1"
             ConfigurableDirectory="INSTALLFOLDER"
             Display="expand"
             Description="ExoSnap recording application">
      <ComponentGroupRef Id="StagingFiles" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

  </Package>
</Wix>
