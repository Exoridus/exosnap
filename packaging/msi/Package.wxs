<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <!--
    ExoSnap MSI Installer
    =====================
    Package identity: Codexo.ExoSnap
    UpgradeCode: 8988DAFC-3AE4-4788-BA6D-62E3F73C7A7D (permanent — ADR 0034, NEVER CHANGE)
    ProductCode is auto-generated per build (*).

    Files are auto-harvested from the pruned CMake install staging tree ($(var.StagingDir)).
    The previous hand-maintained <Component>/<File> list has been eliminated; all binaries,
    DLLs, plugins/, and licenses/ are picked up automatically — including any FFmpeg DLLs
    (avformat-62, avcodec-62, avutil-60, swresample-6), dxcompiler.dll, dxil.dll,
    D3Dcompiler_47.dll, and crashpad_handler.exe (when present) — so the MSI never drifts
    from the portable ZIP contents again.

    The build script passes -d StagingDir=<pruned staging tree root>, which is the same
    source used for the portable ZIP (already audited and pruned by the release script).

    User data is NOT installed or removed by this MSI.
  -->

  <Package Name="ExoSnap"
           Manufacturer="Codexo"
           Version="$(var.ProductVersion)"
           UpgradeCode="8988DAFC-3AE4-4788-BA6D-62E3F73C7A7D"
           Scope="perMachine"
           Language="1033"
           Codepage="1252">

    <MajorUpgrade DowngradeErrorMessage="A newer version of ExoSnap is already installed."
                  AllowSameVersionUpgrades="yes" />

    <Media Id="1" Cabinet="exosnap.cab" EmbedCab="yes" />

    <!-- Directory skeleton: %ProgramFiles%\Codexo\ExoSnap\ -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="ManufacturerFolder" Name="Codexo">
        <Directory Id="INSTALLFOLDER" Name="ExoSnap" />
      </Directory>
    </StandardDirectory>

    <!--
      Auto-harvest: every file in the pruned CMake staging tree is installed into
      INSTALLFOLDER, preserving the relative directory structure (plugins/, licenses/).
      WiX v4 <Files> creates one Component per file with auto-generated stable GUIDs.
      No per-file maintenance needed; new runtime DLLs are included automatically.
    -->
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.StagingDir)\**" />
    </ComponentGroup>

    <!-- Start Menu shortcut (all-users, per-machine) — stable Guid per ADR 0034 -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Component Id="StartMenuShortcut" Guid="{C1D2E3F4-A5B6-7890-CDEF-1234567890AB}" KeyPath="yes">
        <Shortcut Id="StartMenuExoSnap"
                  Name="ExoSnap"
                  Description="Windows-native recording application"
                  Target="[INSTALLFOLDER]exosnap.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKLM"
                       Key="Software\Codexo\ExoSnap"
                       Name="installed"
                       Value="1"
                       Type="integer" />
      </Component>
    </StandardDirectory>

    <!-- ARP (Add/Remove Programs) metadata -->
    <Property Id="ARPCOMMENTS" Value="Windows-native diagnostics-first recording application" />
    <Property Id="ARPCONTACT" Value="https://github.com/Exoridus/exosnap" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/Exoridus/exosnap" />
    <Property Id="ARPHELPLINK" Value="https://github.com/Exoridus/exosnap/issues" />
    <Property Id="ARPNOMODIFY" Value="1" />
    <Property Id="ARPNOREPAIR" Value="0" />

    <!-- Feature tree -->
    <Feature Id="MainFeature"
             Title="ExoSnap"
             Level="1"
             ConfigurableDirectory="INSTALLFOLDER"
             Display="expand"
             Description="ExoSnap recording application">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

  </Package>
</Wix>
