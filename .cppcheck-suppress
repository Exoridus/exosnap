// cppcheck suppress file — add entries as: [error-id]:[file-path]  or  [error-id] for global
// Use //cppcheck-suppress <id> inline in source for single-line local suppressions.

// Win32/DXGI/WASAPI system headers are not provided to cppcheck.
missingIncludeSystem

// GoogleTest TEST() / TEST_F() macros expand to class definitions that cppcheck
// cannot parse without the full GoogleTest headers. Suppress in test files only.
syntaxError:*/tests/*

// Suppress noise when a suppression entry no longer matches (remove once list is stable).
unmatchedSuppression

// WASAPI audio processing routinely casts byte buffers to float* because WASAPI guarantees
// the data is float32-aligned. These casts are correct by design; the portability warning
// is a false positive in this domain.
invalidPointerCast
