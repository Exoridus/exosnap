#!/bin/sh
zero_sha="0000000000000000000000000000000000000000"
has_branch_update=0

while read local_ref local_sha remote_ref remote_sha
do
    case "$local_ref:$remote_ref" in
        refs/heads/*:*|*:refs/heads/*)
            if [ "$local_sha" != "$zero_sha" ] && [ "$local_sha" != "$remote_sha" ]; then
                has_branch_update=1
            fi
            ;;
    esac
done

if [ "$has_branch_update" -eq 0 ]; then
    exit 0
fi

# Static checks only (cppcheck + clang-tidy, ~45 s). The full build + test for both the
# Debug and Release presets is already run by GitHub CI on every push and pull_request
# (.github/workflows/ci.yml), so duplicating a cold Visual-Studio build+test here only
# made every push take minutes. Run scripts/check-quality.ps1 (no -StaticOnly) manually
# when you want the full local gate.
pwsh -NonInteractive -File "$(git rev-parse --show-toplevel)/scripts/check-quality.ps1" -StaticOnly
