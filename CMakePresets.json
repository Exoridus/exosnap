{
  "version": 6,
  "configurePresets": [
    {
      "name": "windows-x64-debug",
      "displayName": "Windows x64 Debug",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-x64-release",
      "displayName": "Windows x64 Release",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "windows-x64-lint",
      "displayName": "Windows x64 Lint",
      "inherits": "windows-x64-debug",
      "cacheVariables": {
        "EXOSNAP_CLANG_TIDY": "ON",
        "EXOSNAP_CPPCHECK": "ON"
      }
    },
    {
      "name": "windows-x64-ninja-debug",
      "displayName": "Windows x64 Ninja Debug",
      "description": "Ninja + MSVC Debug. Run from a VS Developer PowerShell/Command Prompt.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-x64-ninja-release",
      "displayName": "Windows x64 Ninja Release",
      "description": "Ninja + MSVC Release. Run from a VS Developer PowerShell/Command Prompt. Optionally enable sccache: -DEXOSNAP_USE_SCCACHE=ON",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "windows-x64-ninja-lint",
      "displayName": "Windows x64 Ninja Lint",
      "description": "Ninja + MSVC Debug with clang-tidy + cppcheck. Run from a VS Developer PowerShell/Command Prompt.",
      "inherits": "windows-x64-ninja-debug",
      "cacheVariables": {
        "EXOSNAP_CLANG_TIDY": "ON",
        "EXOSNAP_CPPCHECK": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-x64-debug",
      "configurePreset": "windows-x64-debug"
    },
    {
      "name": "windows-x64-debug-exosnap",
      "displayName": "Windows x64 Debug - exosnap app only",
      "configurePreset": "windows-x64-debug",
      "configuration": "Debug",
      "targets": [
        "exosnap"
      ]
    },
    {
      "name": "windows-x64-debug-presentation-state-tests",
      "displayName": "Windows x64 Debug - presentation state tests",
      "configurePreset": "windows-x64-debug",
      "configuration": "Debug",
      "targets": [
        "presentation_state_tests"
      ]
    },
    {
      "name": "windows-x64-release",
      "configurePreset": "windows-x64-release"
    },
    {
      "name": "windows-x64-release-exosnap",
      "displayName": "Windows x64 Release - exosnap app only",
      "configurePreset": "windows-x64-release",
      "configuration": "Release",
      "targets": [
        "exosnap"
      ]
    },
    {
      "name": "windows-x64-lint",
      "configurePreset": "windows-x64-lint"
    },
    {
      "name": "windows-x64-ninja-debug",
      "configurePreset": "windows-x64-ninja-debug"
    },
    {
      "name": "windows-x64-ninja-debug-exosnap",
      "displayName": "Windows x64 Ninja Debug - exosnap app only",
      "configurePreset": "windows-x64-ninja-debug",
      "targets": [
        "exosnap"
      ]
    },
    {
      "name": "windows-x64-ninja-debug-presentation-state-tests",
      "displayName": "Windows x64 Ninja Debug - presentation state tests",
      "configurePreset": "windows-x64-ninja-debug",
      "targets": [
        "presentation_state_tests"
      ]
    },
    {
      "name": "windows-x64-ninja-release",
      "configurePreset": "windows-x64-ninja-release"
    },
    {
      "name": "windows-x64-ninja-release-exosnap",
      "displayName": "Windows x64 Ninja Release - exosnap app only",
      "configurePreset": "windows-x64-ninja-release",
      "targets": [
        "exosnap"
      ]
    },
    {
      "name": "windows-x64-ninja-lint",
      "configurePreset": "windows-x64-ninja-lint"
    }
  ],
  "testPresets": [
    {
      "name": "windows-x64-debug",
      "configurePreset": "windows-x64-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-x64-release",
      "configurePreset": "windows-x64-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-x64-ninja-debug",
      "configurePreset": "windows-x64-ninja-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-x64-ninja-release",
      "configurePreset": "windows-x64-ninja-release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
