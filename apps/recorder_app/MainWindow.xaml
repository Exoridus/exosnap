<Window x:Class="exosnap.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#151A24" Padding="12">
            <StackPanel Spacing="10">
                <TextBlock Text="exosnap" FontSize="20" FontWeight="SemiBold" Margin="4,2,4,12" />
                <ListBox x:Name="NavList" SelectionMode="Single">
                    <ListBoxItem Tag="Record" Content="Record" />
                    <ListBoxItem Tag="Video" Content="Video" />
                    <ListBoxItem Tag="Audio" Content="Audio" />
                    <ListBoxItem Tag="Output" Content="Output" />
                    <ListBoxItem Tag="Hotkeys" Content="Hotkeys" />
                    <ListBoxItem Tag="Diagnostics" Content="Diagnostics" />
                    <ListBoxItem Tag="Logs" Content="Logs" />
                    <ListBoxItem Tag="Advanced" Content="Advanced" />
                </ListBox>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="#0F131A" Padding="12">
            <Frame x:Name="ContentFrame" />
        </Border>
    </Grid>
</Window>
