<Page x:Class="exosnap.AudioPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Margin="24,20,24,24" Spacing="16">
            <TextBlock Text="Audio" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Opacity="0.75"
                       Text="Source ordering and track mapping preview. Drag/drop and live metering wiring follow in later integration." />

            <StackPanel Spacing="6">
                <TextBlock Text="Sources &amp; tracks" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock Opacity="0.75" Text="Default order: APP, MIC, SYS" />
            </StackPanel>

            <Border Background="#1B2230" CornerRadius="6" Padding="12">
                <StackPanel Spacing="6">
                    <TextBlock Text="APP — Selected application audio" FontWeight="SemiBold" />
                    <CheckBox Content="Enabled" IsChecked="True" />
                    <TextBlock Opacity="0.75" Text="Source: Game.exe + child processes" />
                    <TextBlock Opacity="0.75" Text="Meter: ▂▅▇" />
                </StackPanel>
            </Border>

            <Border Background="#1B2230" CornerRadius="6" Padding="12">
                <StackPanel Spacing="6">
                    <TextBlock Text="MIC — Microphone" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <CheckBox Content="Enabled" IsChecked="True" />
                        <CheckBox Content="Merge with above" IsChecked="False" />
                    </StackPanel>
                    <TextBlock Opacity="0.75" Text="Device: Follow Windows default — Shure MV7" />
                    <TextBlock Opacity="0.75" Text="Meter: ▂▃" />
                </StackPanel>
            </Border>

            <Border Background="#1B2230" CornerRadius="6" Padding="12">
                <StackPanel Spacing="6">
                    <TextBlock Text="SYS — Other system audio" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <CheckBox Content="Enabled" IsChecked="True" />
                        <CheckBox Content="Merge with above" IsChecked="False" />
                    </StackPanel>
                    <TextBlock Opacity="0.75" Text="Source: Everything except selected application" />
                    <TextBlock Opacity="0.75" Text="Meter: ▂▅▇" />
                </StackPanel>
            </Border>

            <StackPanel Spacing="6">
                <TextBlock Text="Resulting tracks" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock Text="1. APP" />
                <TextBlock Text="2. MIC" />
                <TextBlock Text="3. SYS" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Encoding" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock Text="Codec: Opus" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
