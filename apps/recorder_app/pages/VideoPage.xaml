<Page x:Class="exosnap.VideoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Margin="24,20,24,24" Spacing="16">
            <TextBlock Text="Video" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Opacity="0.75"
                       Text="Video capture and encoder settings for the current recording profile." />

            <StackPanel Spacing="8">
                <TextBlock Text="Frame rate output" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <RadioButton GroupName="FrameRateGroup" Content="Constant 60 fps" IsChecked="True" />
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock Text="Resolution" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <RadioButton GroupName="ResolutionGroup" Content="Source resolution" IsChecked="True" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <RadioButton GroupName="ResolutionGroup" Content="Scale to" />
                    <ComboBox Width="220" SelectedIndex="0">
                        <ComboBoxItem Content="1920 × 1080" />
                        <ComboBoxItem Content="2560 × 1440" />
                        <ComboBoxItem Content="3840 × 2160" />
                    </ComboBox>
                </StackPanel>
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock Text="Codec" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <RadioButton GroupName="CodecGroup" Content="AV1 (Recommended)" IsChecked="True" />
                <RadioButton GroupName="CodecGroup" Content="HEVC" />
                <RadioButton GroupName="CodecGroup" Content="H.264" />
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock Text="Quality" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <RadioButton GroupName="QualityGroup" Content="High quality" IsChecked="True" />
                <RadioButton GroupName="QualityGroup" Content="Balanced" />
                <RadioButton GroupName="QualityGroup" Content="Smaller files" />
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock Text="Cursor" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <CheckBox Content="Capture mouse cursor" IsChecked="True" />
            </StackPanel>

            <Expander Header="Advanced">
                <StackPanel Spacing="8" Margin="0,8,0,0">
                    <TextBlock Text="Effective encoder: NVENC AV1" />
                    <TextBlock Text="Preset: P5 (Quality)" />
                    <TextBlock Text="Rate control: VBR" />
                    <TextBlock Text="CQ: 20" />
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</Page>
