<Page x:Class="exosnap.RecordPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Margin="24,24,24,24" Spacing="16">
            <TextBlock Text="Record" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Opacity="0.75" Text="Operational view for target selection, readiness, and live runtime stats." />

            <!-- Section A: Capability Banner -->
            <Border x:Name="CapabilityBanner" CornerRadius="4" Padding="12,8">
                <TextBlock x:Name="CapabilityText" TextWrapping="Wrap" />
            </Border>

            <!-- Preview block -->
            <StackPanel Spacing="8">
                <TextBlock Text="Live Preview" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <Border Background="#111827" CornerRadius="6" Padding="12" Height="190">
                    <Grid>
                        <TextBlock Text="Preview surface placeholder"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Opacity="0.7" />
                    </Grid>
                </Border>
                <TextBlock Opacity="0.75" Text="Source metadata and live thumbnail wiring will be attached to capture pipeline output." />
            </StackPanel>

            <!-- Section B: Capture Target -->
            <StackPanel Spacing="8">
                <TextBlock Text="Capture Target" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <ComboBox x:Name="TargetCombo" HorizontalAlignment="Stretch" />
            </StackPanel>

            <!-- Section C: Output Path -->
            <StackPanel Spacing="8">
                <TextBlock Text="Output Path" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock x:Name="OutputPathText" Text="--" TextWrapping="Wrap" Opacity="0.7" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Readiness" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock Opacity="0.75" Text="Start is blocked automatically while active blockers are present." />
            </StackPanel>

            <!-- Section D: Controls -->
            <StackPanel Spacing="8" Orientation="Horizontal">
                <Button x:Name="StartButton" Content="Start Recording" Click="StartButton_Click" Style="{StaticResource AccentButtonStyle}" />
                <Button x:Name="StopButton" Content="Stop Recording" Click="StopButton_Click" />
            </StackPanel>
            <TextBlock x:Name="StateText" />

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Add Marker" />
                <Button Content="Split Recording" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Audio activity" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock Opacity="0.75" Text="APP ▂▅▇    MIC ▂▃    SYS ▂▅▇" />
            </StackPanel>

            <!-- Section E: Live Stats (shown during Recording/Stopping) -->
            <Border x:Name="StatsPanel" CornerRadius="4" Padding="12,8">
                <StackPanel Spacing="4">
                    <TextBlock x:Name="ElapsedText" />
                    <TextBlock x:Name="FramesCapturedText" />
                    <TextBlock x:Name="VideoPacketsText" />
                    <TextBlock x:Name="AudioPacketsText" />
                    <TextBlock x:Name="DroppedFramesText" />
                    <TextBlock x:Name="OutputSizeText" />
                </StackPanel>
            </Border>

            <!-- Section F: Result (shown after Completed/Failed) -->
            <Border x:Name="ResultPanel" CornerRadius="4" Padding="12,8">
                <StackPanel Spacing="4">
                    <TextBlock x:Name="ResultStatusText" />
                    <TextBlock x:Name="ResultOutputPathText" TextWrapping="Wrap" />
                    <TextBlock x:Name="ResultErrorPhaseText" />
                    <TextBlock x:Name="ResultHResultText" />
                    <TextBlock x:Name="ResultErrorDetailText" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
