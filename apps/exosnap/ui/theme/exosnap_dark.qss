}

QWidget#audioTrackPreviewRow {
    background: transparent;
    border-top: 1px solid ${line1};
}

QWidget#audioTrackPreviewRow[firstRow="true"] {
    border-top: none;
}

QLabel[labelRole="audioTrackIndex"] {
    font-family: ${font-mono};
