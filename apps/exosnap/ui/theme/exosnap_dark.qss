    letter-spacing: 0.14em;
    color: ${text3};
}

QLabel[labelRole="aboutMetaValue"] {
    font-family: ${font-mono};
    font-size: 12px;
    letter-spacing: 0.06em;
    font-weight: 600;
    color: ${text1};
}

QPushButton#sidebarAboutButton {
    background: ${bg2};
    border: 1px solid ${line1};
    border-radius: ${radius-sm}px;
    color: ${text2};
    padding: 6px 9px;
    min-height: 28px;
    font-family: ${font-mono};
    font-size: 11px;
    letter-spacing: 0.04em;
    font-weight: 500;
}

QPushButton#sidebarAboutButton:hover {
    color: ${accent};
    border-color: ${line2};
    background: ${bg3};
}

QDialog#sourcePickerDialog {
    background: ${bg1};
    border: 1px solid ${line2};
    border-radius: ${radius-lg}px;
}

QStackedWidget#sourcePickerPages {
    background: ${bg2};
    border: 1px solid ${line2};
    border-radius: ${radius-lg}px;
}

QWidget#sourcePickerSectionTabs {
    background: ${bg3};
    border: 1px solid ${line2};
    border-radius: ${radius-md}px;
    padding: 2px;
}

QPushButton[sourcePickerSection="true"] {
    background: transparent;
    border: 1px solid transparent;
    border-radius: ${radius-sm}px;
    min-height: 30px;
    padding: 4px 14px;
    color: ${text2};
    font-weight: 500;
}

QPushButton[sourcePickerSection="true"]:hover {
    color: ${text0};
    background: ${bg4};
}

QPushButton[sourcePickerSection="true"]:checked {
    border-color: ${accent};
    color: ${accent};
    background: rgba(233, 179, 97, 0.16);
}

QPushButton[sourcePickerSection="true"]:focus {
    border-color: ${accent};
    background: rgba(233, 179, 97, 0.12);
}

QPushButton#sourcePickerRefreshButton {
    min-height: 28px;
    padding: 3px 12px;
}

QPushButton#sourcePickerShowUnavailableButton {
    min-height: 28px;
    padding: 3px 12px;
}

QPushButton#sourcePickerUseButton {
    color: ${bg0};
    background: ${accent};
    border-color: ${accent};
}

QPushButton#sourcePickerUseButton:hover {
    background: ${accent-hover};
    border-color: ${accent-hover};
}

QPushButton#sourcePickerCancelButton {
    min-width: 88px;
}

QLabel#sourcePickerSummary {
    color: ${text2};
}

/* Preview surface text roles */
QLabel[labelRole="previewMeta"] {
    font-family: ${font-mono};
    font-size: 11px;
    letter-spacing: 0.04em;
    color: ${text2};
}

QLabel[labelRole="previewCenterTitle"] {
    font-family: ${font-mono};
    font-size: 13px;
    letter-spacing: 0.12em;
    color: ${text2};
}

QLabel[labelRole="previewCenterSubtitle"] {
    font-family: ${font-mono};
    font-size: 14px;
    letter-spacing: 0.14em;
    color: ${text2};
}

QLabel[labelRole="previewBottomText"] {
    font-family: ${font-mono};
    font-size: 11px;
    letter-spacing: 0.04em;
    color: ${text2};
}

QLabel[labelRole="previewBottomAccent"] {
    font-family: ${font-mono};
    font-size: 11px;
    letter-spacing: 0.1em;
    color: ${text2};
}

/* Reusable generic roles used by existing pages */
QLabel[labelRole="title"] {
    font-size: 22px;
    font-weight: 600;
    color: ${text0};
}

QLabel[labelRole="subtitle"] {
    font-size: 13px;
    color: ${text1};
}

QLabel[labelRole="section"] {
    font-size: 13px;
    font-weight: 600;
    color: ${text0};
}

QLabel[labelRole="cardTitle"] {
    font-size: 15px;
    font-weight: 600;
    color: ${text0};
}

QLabel[labelRole="fieldLabel"] {
    font-family: ${font-mono};
    font-size: 11px;
    letter-spacing: 0.12em;
    color: ${text2};
}

QLabel[labelRole="body"] {
    font-size: 13px;
    color: ${text1};
}

QLabel[labelRole="muted"] {
    font-size: 12px;
    color: ${text2};
}

QLabel[labelRole="profileStatusBadge"] {
    font-family: ${font-mono};
    font-size: 10px;
    letter-spacing: 0.08em;
    color: ${text1};
    border: 1px solid ${line2};
    border-radius: ${radius-sm}px;
    padding: 1px 6px;
    background: ${bg3};
}

QLabel[labelRole="profileStatusBadge"][stateRole="ready"] {
    color: ${ok};
    border-color: rgba(120, 218, 149, 0.48);
    background: rgba(120, 218, 149, 0.14);
}

QLabel[labelRole="profileStatusBadge"][stateRole="warn"] {
    color: ${warn};
    border-color: rgba(194, 150, 83, 0.52);
    background: rgba(194, 150, 83, 0.16);
}

QLabel[labelRole="profileStatusBadge"][stateRole="recording"] {
    color: ${err};
    border-color: rgba(240, 91, 84, 0.58);
    background: rgba(240, 91, 84, 0.18);
}

QLabel[labelRole="profileStatusBadge"][stateRole="blocked"] {
    color: ${err};
    border-color: rgba(240, 91, 84, 0.62);
    background: rgba(240, 91, 84, 0.2);
}

QLabel[labelRole="subtle"] {
    font-size: 12px;
    color: ${text3};
}

QLabel[labelRole="signal"] {
    font-size: 12px;
    color: ${accent};
}

QLabel[labelRole="countBlocker"] {
    font-family: ${font-mono};
    font-size: 15px;
    font-weight: 600;
    color: ${err};
}

QLabel[labelRole="countNotice"] {
    font-family: ${font-mono};
    font-size: 15px;
    font-weight: 600;
    color: ${warn};
}

QLabel[labelRole="countPass"] {
    font-family: ${font-mono};
    font-size: 15px;
    font-weight: 600;
    color: ${ok};
}

QLabel[labelRole="statusGood"] {
    color: ${ok};
    font-weight: 600;
}

QLabel[labelRole="statusBad"] {
    color: ${err};
    font-weight: 600;
}

QLabel[labelRole="ok"] {
    font-size: 12px;
    font-weight: 600;
    color: ${ok};
}

QLabel[labelRole="err"] {
    font-size: 12px;
    font-weight: 600;
    color: ${err};
}

QLabel[labelRole="mono"] {
    font-family: ${font-mono};
    font-size: 12px;
    color: ${text1};
    font-weight: 500;
}

QLabel[stateRole="muted"] {
    color: ${text2};
}

QLabel[stateRole="ready"] {
    color: ${ok};
}

QLabel[stateRole="recording"] {
    color: ${err};
}

QLabel[stateRole="blocked"] {
    color: ${err};
}

/* Diagnostics — readiness stat tiles */
QFrame[panelRole="statTile"],
QWidget[panelRole="statTile"] {
    background: ${bg3};
    border: 1px solid ${line2};
    border-radius: ${radius-md}px;
}

QFrame[panelRole="statTile"][statTone="blocker"] {
    border-color: rgba(240, 91, 84, 0.42);
    background: rgba(240, 91, 84, 0.10);
}

QFrame[panelRole="statTile"][statTone="notice"] {
    border-color: rgba(194, 150, 83, 0.42);
    background: rgba(194, 150, 83, 0.10);
}

QFrame[panelRole="statTile"][statTone="pass"] {
    border-color: rgba(120, 218, 149, 0.40);
    background: rgba(120, 218, 149, 0.08);
}

QLabel[labelRole="statTileNum"] {
    font-family: ${font-mono};
    font-size: 26px;
    font-weight: 600;
    color: ${text0};
}

QLabel[labelRole="statTileNum"][statTone="blocker"] {
    color: ${err};
}

QLabel[labelRole="statTileNum"][statTone="notice"] {
    color: ${warn};
}

QLabel[labelRole="statTileNum"][statTone="pass"] {
    color: ${ok};
}

QLabel[labelRole="statTileLabel"] {
    font-size: 12.5px;
    color: ${text2};
}

/* Diagnostics — issue / recommendation cards */
QFrame[panelRole="issueCard"],
QWidget[panelRole="issueCard"] {
    background: ${bg2};
    border: 1px solid ${line2};
    border-radius: ${radius-lg}px;
}

QFrame[panelRole="issueCard"][issueTone="blocker"] {
    border-color: rgba(240, 91, 84, 0.48);
    background: rgba(240, 91, 84, 0.10);
}

QFrame[panelRole="issueCard"][issueTone="notice"] {
    border-color: rgba(194, 150, 83, 0.48);
    background: rgba(194, 150, 83, 0.10);
}

QFrame[panelRole="issueCard"][issueTone="pass"] {
    border-color: rgba(120, 218, 149, 0.36);
    background: rgba(120, 218, 149, 0.07);
}

QLabel[labelRole="issueTitle"] {
    font-size: 14px;
    font-weight: 600;
    color: ${text0};
}

QLabel[labelRole="issueDesc"] {
    font-size: 12.5px;
    color: ${text1};
}

QLabel[labelRole="issueMeta"] {
    font-family: ${font-mono};
    font-size: 10.5px;
    letter-spacing: 0.03em;
    color: ${text2};
}

/* Diagnostics — severity glyphs reused for tiles, issues and self-test rows */
QLabel[labelRole="pass"] {
    color: ${ok};
    font-weight: 600;
}

QLabel[labelRole="notice"] {
    color: ${warn};
    font-weight: 600;
}

QLabel[labelRole="blocker"] {
    color: ${err};
    font-weight: 600;
}

/* Diagnostics — collapsible "Technical details" disclosure heads */
QToolButton[role="collapseHead"] {
    background: ${bg2};
    border: 1px solid ${line2};
    border-radius: ${radius-lg}px;
    padding: 12px 16px;
    color: ${text0};
    font-family: ${font-sans};
    font-size: 14px;
    font-weight: 600;
    text-align: left;
}

QToolButton[role="collapseHead"]:hover {
    background: ${bg3};
    border-color: ${line3};
    color: ${text0};
}

QToolButton[role="collapseHead"]:checked {
    border-color: ${line3};
}

QToolButton[role="collapseHead"]:focus {
    border-color: ${accent};
}

QLabel[labelRole="collapseSub"] {
    font-size: 12px;
    color: ${text2};
}

/* Diagnostics — capability / configuration table */
QLabel[labelRole="tableHeader"] {
    font-family: ${font-mono};
    font-size: 10.5px;
    letter-spacing: 0.1em;
    color: ${text3};
}

QWidget#diagTableRow {
    background: transparent;
    border-top: 1px solid ${line1};
}

QWidget#diagTableRow[firstRow="true"] {
    border-top: none;
}

/* Diagnostics — self-test rows */
QFrame[panelRole="selfTestRow"],
QWidget[panelRole="selfTestRow"] {
    background: ${bg3};
    border: 1px solid ${line2};
    border-radius: ${radius-md}px;
}

QLabel[labelRole="selfTestTitle"] {
    font-size: 13.5px;
    color: ${text0};
}

QLabel[labelRole="selfTestDetail"] {
    font-size: 12px;
    color: ${text2};
}

/* Diagnostics — planned / post-MVP note strip */
QFrame[panelRole="plannedNote"],
QWidget[panelRole="plannedNote"] {
    background: ${bg2};
    border: 1px dashed ${line3};
    border-radius: ${radius-md}px;
}

QLabel[labelRole="plannedTag"] {
    font-family: ${font-mono};
    font-size: 9px;
    letter-spacing: 0.14em;
    color: ${text3};
    border: 1px solid ${line2};
    border-radius: ${radius-sm}px;
    padding: 2px 7px;
}

/* Logs — raw viewer surface */
QPlainTextEdit#logViewer {
    background: ${bg0};
    color: ${text1};
    border: 1px solid ${line2};
    border-radius: ${radius-md}px;
    padding: 12px 14px;
    font-family: ${font-mono};
    font-size: 12px;
    selection-background-color: ${accent-dim};
    selection-color: ${text0};
}

QPlainTextEdit#logViewer:focus {
    border-color: ${line3};
}

QLabel[labelRole="logStatus"] {
    font-family: ${font-mono};
    font-size: 11px;
    letter-spacing: 0.02em;
    color: ${text2};
}

QLineEdit,
QComboBox,
QKeySequenceEdit {
    background: ${bg3};
    border: 1px solid ${line2};
    border-radius: ${radius-md}px;
    padding: 0 ${space-md}px;
    color: ${text0};
    min-height: ${control-height}px;
}

QLineEdit:hover,
QComboBox:hover,
QKeySequenceEdit:hover {
    border-color: ${line3};
    background: ${bg4};
}

QLineEdit:focus,
QComboBox:focus,
QKeySequenceEdit:focus {
    border: 1px solid ${accent};
    background: ${bg4};
}

QLineEdit:disabled,
QComboBox:disabled,
QKeySequenceEdit:disabled {
    color: ${text3};
    background: ${bg2};
    border: 1px solid ${line1};
}

QKeySequenceEdit[role="capture"] {
    border-color: ${accent};
    background: rgba(233, 179, 97, 0.1);
}

QComboBox::drop-down {
    background: transparent;
    border: none;
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 28px;
    padding-right: 8px;
}

QComboBox {
    padding-right: 34px;
    combobox-popup: 0;
}

QComboBox::down-arrow {
    image: url(:/theme/icons/chevron-down.svg);
    width: 12px;
    height: 12px;
}

QComboBox::down-arrow:disabled {
    image: url(:/theme/icons/chevron-down.svg);
}

QComboBox QAbstractItemView {
    background: ${bg1};
    border: 1px solid ${line2};
    border-radius: ${radius-md}px;
    padding: 4px;
    selection-background-color: rgba(233, 179, 97, 0.2);
    selection-color: ${text0};
    color: ${text1};
    outline: none;
}

QComboBox QAbstractItemView::item {
    min-height: 26px;
    padding: 5px 10px;
    margin: 1px 2px;
    border-radius: ${radius-sm}px;
}

QComboBox QAbstractItemView::item:hover {
    background: ${bg4};
    color: ${text0};
}

QComboBox QAbstractItemView::item:selected {
    background: rgba(233, 179, 97, 0.22);
    color: ${text0};
}

QPushButton {
    background: ${bg3};
    border: 1px solid ${line2};
    border-radius: ${radius-md}px;
    padding: 0 ${space-lg}px;
    color: ${text0};
    min-height: ${control-height}px;
    font-weight: 600;
}

QPushButton:hover {
    background: ${bg4};
    border-color: ${line3};
    color: ${text0};
}

QPushButton:pressed {
    background: ${bg2};
}

QPushButton:disabled {
    color: ${text3};
    background: ${bg2};
    border-color: ${line1};
    opacity: 0.72;
}

QPushButton:focus {
    border-color: ${accent};
}

QPushButton[role="primary"] {
    color: ${bg0};
    background: ${accent};
    border-color: ${accent};
}

QPushButton[role="primary"]:hover {
    background: ${accent-hover};
    border-color: ${accent-hover};
}

QPushButton[role="primary"]:disabled {
    color: ${text2};
    background: ${bg3};
    border-color: ${line2};
}

QPushButton[role="danger"] {
    color: ${err};
    background: rgba(240, 91, 84, 0.12);
    border-color: rgba(240, 91, 84, 0.58);
}

QPushButton[role="danger"]:hover {
    background: rgba(240, 91, 84, 0.22);
    border-color: rgba(240, 91, 84, 0.74);
}

QPushButton[role="ghost"] {
    background: transparent;
    color: ${text1};
    border: 1px solid ${line2};
}

QPushButton[role="ghost"]:hover {
    background: ${bg3};
    border-color: ${line3};
}

QPushButton[role="utility"] {
    background: ${bg3};
    border: 1px solid ${line2};
    color: ${text1};
    min-height: 30px;
    padding: 0 12px;
    font-size: 12px;
    font-weight: 500;
}

QPushButton[role="utility"]:hover {
    background: ${bg4};
    border-color: ${line3};
    color: ${text0};
}

QToolButton {
    background: ${bg3};
    border: 1px solid ${line2};
    border-radius: ${radius-md}px;
    padding: 6px ${space-lg}px;
    color: ${text1};
    min-height: ${control-height}px;
}

QToolButton:hover {
    background: ${bg4};
    border-color: ${line3};
    color: ${text0};
}

QToolButton:disabled {
    color: ${text3};
    background: ${bg2};
    border-color: ${line1};
}

QToolButton::menu-indicator {
    subcontrol-origin: padding;
    subcontrol-position: center right;
    right: 6px;
    image: url(:/theme/icons/chevron-down.svg);
    width: 12px;
    height: 12px;
}

QPushButton[role="link"] {
    background: transparent;
    border: none;
    color: ${text2};
    padding: ${space-sm}px 0;
    min-height: 0;
    text-align: left;
}

QPushButton[role="link"]:hover {
    color: ${accent};
    background: transparent;
}

QCheckBox,
QRadioButton {
    color: ${text1};
    spacing: 8px;
    font-size: 13px;
}

QCheckBox::indicator {
    width: 14px;
    height: 14px;
    border: 1px solid ${line2};
    border-radius: 3px;
    background: ${bg4};
}

QCheckBox::indicator:checked {
    border: 1px solid ${accent};
    background: ${accent};
}

QCheckBox::indicator:disabled {
    border-color: ${line2};
    background: #1a1714;
}

QRadioButton::indicator {
    width: 16px;
    height: 16px;
    border: 1px solid ${line2};
    border-radius: 8px;
    background: ${bg2};
}

QRadioButton::indicator:checked {
    border-color: ${line2};
    background: ${accent};
}

QRadioButton::indicator:hover {
    border-color: rgba(215, 167, 68, 102);
}

QScrollBar:vertical {
    background: transparent;
    width: 11px;
    margin: 2px;
}

QScrollBar::handle:vertical {
    background: ${bg3};
    min-height: 24px;
    border-radius: 6px;
}

QScrollBar::handle:vertical:hover {
    background: ${line3};
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0;
}

QScrollBar:horizontal {
    background: transparent;
    height: 11px;
    margin: 2px;
}

QScrollBar::handle:horizontal {
    background: ${bg3};
    min-width: 24px;
    border-radius: 6px;
}

QScrollBar::handle:horizontal:hover {
    background: ${line3};
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0;
}

QSlider::groove:horizontal {
    background: ${bg3};
    border: 1px solid ${line1};
    height: 4px;
    border-radius: 2px;
}

QSlider::handle:horizontal {
    background: ${accent};
    border: none;
    width: 14px;
    height: 14px;
    margin: -5px 0;
    border-radius: 7px;
}

QSlider::handle:horizontal:hover {
    background: ${accent-hover};
}

QSlider::handle:horizontal:disabled {
    background: ${line2};
}

QSlider::sub-page:horizontal {
    background: ${accent-dim};
    height: 4px;
    border-radius: 2px;
}

QSlider::sub-page:horizontal:disabled {
    background: ${bg4};
}

QSlider::add-page:horizontal {
    background: transparent;
}

QToolTip {
    background: ${bg2};
    color: ${text0};
    border: 1px solid ${line2};
    padding: ${space-xs}px ${space-sm}px;
}

/* Detail page header — back affordance for sub-pages (Webcam, Advanced) */
QPushButton[role="back"] {
    background: transparent;
    border: none;
    color: ${text2};
    padding: 0 4px 0 0;
    min-height: 0;
    font-size: 13px;
    font-weight: 500;
    text-align: left;
}

QPushButton[role="back"]:hover {
    color: ${accent};
    background: transparent;
}

QPushButton[role="back"]:pressed {
    color: ${accent};
    background: transparent;
}

QLabel[labelRole="detailBreadcrumb"] {
    font-size: 13px;
    color: ${text2};
    font-weight: 400;
}
