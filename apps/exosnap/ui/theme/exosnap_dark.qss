QLabel[labelRole="resultTechnical"] {
    font-family: ${font-mono};
    font-size: 10px;
    color: ${text3};
}

QDialog#aboutDialog {
    background: ${bg1};
    border: 1px solid ${line2};
    border-radius: ${radius-lg}px;
}

QLabel[labelRole="aboutAppName"] {
    font-size: 22px;
