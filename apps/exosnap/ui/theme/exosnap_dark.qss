QMainWindow {
    background: ${bg0};
    color: ${text0};
}

QWidget {
    color: ${text0};
    font-family: ${font-sans};
    selection-background-color: ${accent-dim};
    selection-color: ${text0};
}

QWidget#mainCentral {
    background: ${bg0};
}

/* Operational titlebar */
QWidget#operationalTitleBar {
    background: ${bg1};
}

QWidget#titlebarBrandSlot,
QWidget#titlebarDragSlot,
QWidget#titlebarStatusSlot {
    background: transparent;
}

QLabel[labelRole="titlebarWordmark"] {
    font-family: ${font-sans};
    font-size: 13px;
    letter-spacing: 0.04em;
    font-weight: 500;
    color: ${text0};
}

QPushButton#titlebarWindowButton {
    border: none;
    border-radius: 0;
    background: transparent;
    color: ${text2};
    font-family: ${font-mono};
    font-size: 13px;
}

QPushButton#titlebarWindowButton:hover {
    background: ${bg3};
    color: ${text0};
}

QPushButton#titlebarWindowButton[windowControlRole="close"]:hover {
    background: #b8261d;
    color: #ffffff;
}

/* Global recording status bar */
QWidget#globalRecordingBar {
    background: ${bg2};
    border-top: 1px solid ${line1};
    border-bottom: 1px solid ${line1};
}

/* Sidebar */
QWidget#mainSidebar {
    background: ${bg1};
    border-right: 1px solid ${line1};
}

QFrame#sidebarRule {
    background: ${line1};
    border: none;
    min-height: 1px;
    max-height: 1px;
}

QListWidget#mainNav {
    background: transparent;
    border: none;
    outline: none;
    padding: 0;
}

QListWidget#mainNav::item {
    border: none;
    background: transparent;
}

QWidget#sidebarFooter {
    background: transparent;
}

/* Page header */
QWidget#mainContent {
    background: ${bg0};
}

QWidget#mainPageHead {
    background: transparent;
    border-bottom: 1px solid ${line1};
}

QLabel[labelRole="pageKicker"] {
    font-family: ${font-mono};
    font-size: 11px;
    letter-spacing: 0.14em;
    color: ${text2};
}

QLabel[labelRole="pageTitle"] {
    font-size: 22px;
    font-weight: 500;
    color: ${text0};
}

QLabel[labelRole="pageSubtitle"] {
    font-size: 13px;
    color: ${text2};
}

QLabel[labelRole="pageMeta"] {
    font-family: ${font-mono};
    font-size: 12px;
    letter-spacing: 0.06em;
    color: ${text2};
}

QStackedWidget#mainStack {
    background: transparent;
}

QScrollArea {
    background: transparent;
    border: none;
}

QScrollArea > QWidget > QWidget {
    background: transparent;
}

/* Shared section header */
QLabel[labelRole="sectionRuleTitle"] {
    font-family: ${font-mono};
    font-size: 12px;
    letter-spacing: 0.16em;
    font-weight: 500;
    color: ${text2};
}

QLabel[labelRole="sectionRuleMeta"] {
    font-family: ${font-mono};
    font-size: 12px;
    letter-spacing: 0.06em;
    color: ${text2};
}

QFrame[frameRole="sectionRuleLine"] {
    background: ${line1};
    border: none;
    min-height: 1px;
    max-height: 1px;
}

/* Generic panels */
QFrame[panelRole="panel"],
QWidget[panelRole="panel"] {
    background: ${bg2};
    border: 1px solid ${line2};
    border-radius: ${radius-lg}px;
}

QFrame[panelRole="note"],
QWidget[panelRole="note"] {
    background: ${bg3};
    border: 1px solid ${line2};
    border-radius: ${radius-lg}px;
    padding: ${space-sm}px ${space-md}px;
}

QFrame[panelRole="blocker"],
QWidget[panelRole="blocker"] {
    background: rgba(240, 91, 84, 0.12);
    border: 1px solid rgba(240, 91, 84, 0.48);
    border-radius: ${radius-lg}px;
    padding: ${space-sm}px ${space-md}px;
}

QFrame[panelRole="compactRow"],
QWidget[panelRole="compactRow"] {
    background: ${bg3};
    border: 1px solid ${line2};
    border-radius: ${radius-md}px;
    padding: ${space-sm}px ${space-md}px;
}

/* Settings readiness banner: neutral while checking, tinted when ready/blocked. */
QFrame[panelRole="readinessBanner"],
QWidget[panelRole="readinessBanner"] {
    background: ${bg3};
    border: 1px solid ${line2};
    border-radius: ${radius-lg}px;
}

QFrame[panelRole="readinessBanner"][stateRole="ready"] {
    background: rgba(120, 218, 149, 0.13);
    border-color: rgba(120, 218, 149, 0.42);
}

QFrame[panelRole="readinessBanner"][stateRole="warn"] {
    background: rgba(194, 150, 83, 0.12);
    border-color: rgba(194, 150, 83, 0.48);
}

QFrame[panelRole="readinessBanner"][stateRole="blocked"] {
    background: rgba(240, 91, 84, 0.12);
    border-color: rgba(240, 91, 84, 0.48);
}

/* Settings - capture quality segmented control */
QWidget#qualitySegmented {
    background: ${bg2};
    border: 1px solid ${line2};
    border-radius: ${radius-md}px;
}

QPushButton[qualitySegment="true"] {
    min-height: 32px;
    padding: 0 12px;
    background: transparent;
    border: none;
    border-radius: ${radius-sm}px;
    color: ${text1};
    font-size: 12.5px;
    text-align: center;
}

QPushButton[qualitySegment="true"]:hover {
    background: ${bg3};
    color: ${text0};
}

QPushButton[qualitySegment="true"]:checked,
QPushButton[qualitySegment="true"][qualitySegmentSelected="true"] {
    background: ${accent};
    color: ${bg0};
    font-weight: 600;
}

QPushButton[qualitySegment="true"]:checked:hover,
QPushButton[qualitySegment="true"][qualitySegmentSelected="true"]:hover {
    background: ${accent-hover};
    color: ${bg0};
}

QPushButton[qualitySegment="true"]:disabled {
    color: ${text3};
    background: transparent;
}

QPushButton[qualitySegment="true"]:checked:disabled,
QPushButton[qualitySegment="true"][qualitySegmentSelected="true"]:disabled {
    background: ${bg3};
    color: ${text3};
}

/* Record page */
QLabel[labelRole="recordCapabilityBanner"] {
    font-size: 13px;
    color: ${text1};
}

QFrame#recordControlPanel {
    background: ${bg2};
    border-color: ${line3};
}

QFrame#recordControlPanel[stateRole="ready"] {
    background: rgba(120, 218, 149, 0.06);
    border-color: rgba(120, 218, 149, 0.34);
}

QFrame#recordControlPanel[stateRole="recording"] {
    background: rgba(240, 91, 84, 0.08);
    border-color: rgba(240, 91, 84, 0.42);
}

QFrame#recordControlPanel[stateRole="paused"] {
    background: rgba(215, 167, 68, 0.08);
    border-color: rgba(215, 167, 68, 0.42);
}

QFrame#recordControlPanel[stateRole="done"] {
    background: rgba(120, 218, 149, 0.08);
    border-color: rgba(120, 218, 149, 0.42);
}

QFrame#recordControlPanel[stateRole="blocked"] {
    background: rgba(240, 91, 84, 0.08);
    border-color: rgba(240, 91, 84, 0.42);
}

QLabel[labelRole="recordControlState"] {
    font-family: ${font-mono};
    font-size: 12px;
    letter-spacing: 0.1em;
    font-weight: 600;
    color: ${text2};
}

QLabel[labelRole="recordControlState"][stateRole="ready"] {
    color: ${ok};
}

QLabel[labelRole="recordControlState"][stateRole="recording"] {
    color: ${err};
}

QLabel[labelRole="recordControlState"][stateRole="warn"] {
    color: ${warn};
}

QLabel[labelRole="recordControlState"][stateRole="done"] {
    color: ${ok};
}

QLabel[labelRole="recordControlState"][stateRole="blocked"] {
    color: ${err};
}

QLabel[labelRole="recordHotkeyBadge"] {
    font-family: ${font-mono};
    font-size: 11px;
    letter-spacing: 0.08em;
    color: ${text1};
    border: 1px solid ${line2};
    border-radius: ${radius-sm}px;
    padding: 4px 8px;
    background: ${bg1};
}

QLabel[labelRole="recordTimer"] {
    font-family: ${font-mono};
    font-size: 40px;
    letter-spacing: 0.04em;
    color: ${text2};
    font-weight: 600;
}

QLabel[labelRole="recordTimer"][timerState="recording"] {
    color: ${err};
}

QLabel[labelRole="recordTimer"][timerState="paused"] {
    color: ${warn};
}

QLabel[labelRole="recordTimer"][timerState="done"] {
    color: ${ok};
}

QLabel[labelRole="recordTimer"][timerState="blocked"] {
    color: ${err};
}

QPushButton#recordHeroBtn {
    min-height: 48px;
    font-size: 13px;
    font-weight: 600;
    border-radius: 8px;
}

QPushButton#recordHeroBtn[heroRole="start"] {
    color: #0d150f;
    background: ${ok};
    border-color: ${ok};
}

QPushButton#recordHeroBtn[heroRole="start"]:hover {
    background: #86e1a0;
    border-color: #86e1a0;
}

QPushButton#recordHeroBtn[heroRole="stop"] {
    color: #ffffff;
    border-color: ${err};
    background: ${err};
}

QPushButton#recordHeroBtn[heroRole="stop"]:hover {
    background: #ff645d;
    border-color: ${err};
}

QPushButton#recordHeroBtn[heroRole="resume"] {
    color: ${ok};
    border-color: rgba(120, 218, 149, 0.52);
    background: rgba(120, 218, 149, 0.12);
}

QPushButton#recordHeroBtn[heroRole="resume"]:hover {
    background: rgba(120, 218, 149, 0.2);
    border-color: rgba(120, 218, 149, 0.68);
}

QPushButton#recordHeroBtn[heroRole="blocked"],
QPushButton#recordHeroBtn[heroRole="muted"] {
    color: ${text3};
    border-color: ${line1};
    background: ${bg2};
}

QLabel[labelRole="railSummary"] {
    font-family: ${font-mono};
    font-size: 11px;
    letter-spacing: 0.04em;
    color: ${text2};
}

QWidget#recordRailSourceStatusPanel {
    border: 1px solid ${line1};
    border-radius: ${radius-sm}px;
    background: rgba(33, 30, 27, 0.78);
    padding: 6px;
}

QWidget#recordRailSourceStatusPanel[sourceLocked="true"] {
    border-color: rgba(215, 167, 68, 0.44);
    background: rgba(33, 30, 27, 0.86);
}

QLabel[labelRole="railSourceSummary"] {
    font-family: ${font-mono};
    font-size: 10.5px;
    letter-spacing: 0.04em;
    color: ${text2};
}

QLabel[labelRole="recordRailSourceChip"] {
    font-family: ${font-mono};
    font-size: 10px;
    letter-spacing: 0.06em;
    color: ${text2};
    border: 1px solid ${line2};
    border-radius: ${radius-sm}px;
    background: ${bg3};
    padding: 8px 9px;
}

QLabel[labelRole="recordRailSourceChip"][stateRole="ready"] {
    color: ${ok};
    border-color: rgba(120, 218, 149, 0.46);
    background: rgba(120, 218, 149, 0.14);
}

QLabel[labelRole="recordRailSourceChip"][stateRole="muted"] {
    color: ${text3};
    border-color: ${line1};
    background: ${bg2};
}

QLabel[labelRole="railReadiness"] {
    font-size: 12px;
    color: ${text1};
}

QLabel[labelRole="railReadiness"][stateRole="ready"] {
    color: ${ok};
}

QLabel[labelRole="railReadiness"][stateRole="warn"] {
    color: ${warn};
}

QLabel[labelRole="railReadiness"][stateRole="blocked"] {
    color: ${err};
}

QLabel[labelRole="railReadiness"][stateRole="muted"] {
    color: ${text2};
}

QLabel[labelRole="railStats"] {
    font-family: ${font-mono};
    font-size: 10.5px;
    letter-spacing: 0.04em;
    color: ${text2};
}

QFrame#recordRailStatsGrid {
    border: 1px solid ${line2};
    border-radius: ${radius-sm}px;
    background: ${bg1};
}

QFrame[panelRole="recordRailStatCell"] {
    border: none;
    border-top: 1px solid ${line1};
    border-left: 1px solid ${line1};
}

QLabel[labelRole="railStatKey"] {
    font-family: ${font-mono};
    font-size: 9.5px;
    letter-spacing: 0.12em;
    color: ${text3};
}

QLabel[labelRole="railStatValue"] {
    font-family: ${font-mono};
    font-size: 26px;
    font-weight: 600;
    color: ${text0};
}

/* Readiness strip below the preview: a quiet hairline-bordered strip, not a filled card. */
QFrame#recordReadinessPanel {
    background: transparent;
    border: 1px solid ${line1};
}

QWidget#recordSourceRow {
    background: transparent;
}

QWidget#recordSourceRow[sourceLocked="true"] {
    background: transparent;
}

QWidget#recordPreviewContextRow {
    background: transparent;
}

QWidget#recordPreviewSurfaceHost {
    background: #0a0908;
    border: 1px solid ${line2};
    border-radius: ${radius-md}px;
}

QWidget#recordPreviewSurfaceHost[recordState="ready"] {
    border-color: ${line2};
}

QWidget#recordPreviewSurfaceHost[recordState="recording"] {
    border-color: rgba(240, 91, 84, 0.66);
}

QWidget#recordPreviewSurfaceHost[recordState="paused"] {
    border-color: rgba(215, 167, 68, 0.64);
}

QWidget#recordPreviewSurfaceHost[recordState="warn"] {
    border-color: rgba(215, 167, 68, 0.52);
}

QWidget#recordPreviewSurfaceHost[recordState="blocked"] {
    border-color: rgba(240, 91, 84, 0.7);
}

QWidget#recordPreviewSurfaceHost[recordState="done"] {
    border-color: rgba(120, 218, 149, 0.44);
}

QLabel[labelRole="recordPreviewSourceChip"] {
    font-family: ${font-mono};
    font-size: 10.5px;
    letter-spacing: 0.05em;
    color: ${text2};
    border: 1px solid ${line2};
    border-radius: ${radius-sm}px;
    background: rgba(25, 23, 20, 0.92);
    padding: 4px 8px;
}

QLabel[labelRole="recordPreviewSourceChip"][stateRole="ready"] {
    color: ${ok};
    border-color: rgba(120, 218, 149, 0.44);
    background: rgba(120, 218, 149, 0.12);
}

QLabel[labelRole="recordPreviewSourceChip"][stateRole="recording"] {
    color: ${err};
    border-color: rgba(240, 91, 84, 0.58);
    background: rgba(240, 91, 84, 0.16);
}

QLabel[labelRole="recordPreviewSourceChip"][stateRole="warn"] {
    color: ${warn};
    border-color: rgba(215, 167, 68, 0.5);
    background: rgba(215, 167, 68, 0.15);
}

QLabel[labelRole="recordPreviewSourceChip"][stateRole="blocked"] {
    color: ${err};
    border-color: rgba(240, 91, 84, 0.6);
    background: rgba(240, 91, 84, 0.18);
}

QLabel[labelRole="recordPreviewSourceChip"][stateRole="muted"] {
    color: ${text3};
    border-color: ${line1};
    background: ${bg2};
}

QFrame#recordSourceChip {
    background: rgba(25, 23, 20, 0.92);
    border: 1px solid ${line2};
    border-radius: ${radius-sm}px;
}

QFrame#recordSourceChip[sourceLocked="true"] {
    border-color: rgba(215, 167, 68, 0.48);
    border-style: dashed;
    background: rgba(50, 46, 43, 0.84);
}

QLabel[labelRole="recordSourceKind"] {
    font-family: ${font-mono};
    font-size: 9px;
    letter-spacing: 0.1em;
    color: ${text3};
}

QLabel[labelRole="recordSourceName"] {
    font-family: ${font-mono};
    font-size: 10.5px;
    letter-spacing: 0.05em;
    color: ${text1};
}

QLabel[labelRole="recordSourceMeta"] {
    font-family: ${font-mono};
    font-size: 10px;
    letter-spacing: 0.04em;
    color: ${text2};
}

QLabel[labelRole="recordPresetSummary"] {
    font-family: ${font-mono};
    font-size: 10px;
    letter-spacing: 0.08em;
    color: ${text3};
}

QLabel[labelRole="recordSourceLock"] {
    font-family: ${font-mono};
    font-size: 10px;
    letter-spacing: 0.08em;
    color: ${warn};
    border: 1px solid rgba(215, 167, 68, 0.48);
    border-radius: ${radius-sm}px;
    background: rgba(215, 167, 68, 0.12);
    padding: 3px 8px;
}

QPushButton#recordChangeSourceButton {
    min-height: 30px;
    min-width: 118px;
    padding: 0 12px;
}

QPushButton#recordOpenDiagnosticsButton {
    min-height: 34px;
}

QLabel[labelRole="audioSettingsGroupTitle"] {
    font-family: ${font-mono};
    font-size: 11px;
    letter-spacing: 0.14em;
    color: ${text2};
}

QLabel[labelRole="audioSettingsRowLabel"] {
    font-family: ${font-mono};
    font-size: 11px;
    letter-spacing: 0.08em;
    color: ${text2};
    min-width: 92px;
}

QLabel[labelRole="audioSettingsNote"] {
    font-size: 11.5px;
    color: ${text2};
}

QWidget#captureTargetCard {
    background: ${bg2};
    border: 1px solid ${line2};
    border-radius: ${radius-lg}px;
}

QWidget#captureTargetCard:hover {
    background: ${bg3};
    border-color: ${line3};
}

QWidget#captureTargetCard[selected="true"] {
    background: rgba(233, 179, 97, 0.12);
    border-color: ${accent};
}

QWidget#captureTargetCard[captureCardTone="warning"] {
    border-color: rgba(194, 150, 83, 0.58);
    background: rgba(194, 150, 83, 0.12);
}

QWidget#captureTargetCard[captureCardTone="warning"]:hover {
    border-color: ${warn};
    background: rgba(194, 150, 83, 0.2);
}

QWidget#captureTargetCard[captureCardTone="warning"][selected="true"] {
    border-color: ${warn};
    background: rgba(194, 150, 83, 0.24);
}

QWidget#captureTargetCard:disabled {
    background: ${bg1};
    border-color: ${line1};
    color: ${text3};
}

QWidget#captureTargetCard[unavailable="true"] {
    background: rgba(194, 150, 83, 0.08);
    border-color: rgba(194, 150, 83, 0.42);
}

QWidget#captureTargetCard[captureCardState="minimized"] {
    border-style: dashed;
}

QWidget#captureTargetCard[captureCardState="too-small"] {
    border-color: rgba(194, 150, 83, 0.68);
}

QWidget#captureTargetCard:focus {
    border-color: ${accent};
    background: rgba(233, 179, 97, 0.16);
}

QFrame#captureCardThumbnailSurface {
    background: ${bg3};
    border: 1px solid ${line2};
    border-radius: ${radius-md}px;
}

QFrame#captureCardThumbnailSurface[thumbnailState="ready"] {
    border-color: ${line2};
}

QFrame#captureCardThumbnailSurface[thumbnailState="loading"] {
    background: rgba(39, 36, 32, 0.92);
}

QFrame#captureCardThumbnailSurface[thumbnailState="failed"] {
    border-color: ${warn};
    background: rgba(194, 150, 83, 0.16);
}

QFrame#captureCardThumbnailSurface[thumbnailState="unavailable"] {
    border-color: ${warn};
    background: rgba(194, 150, 83, 0.18);
}

QLabel[labelRole="captureCardThumbnail"] {
    background: transparent;
    border: none;
}

QLabel[labelRole="captureCardThumbnailState"] {
    font-family: ${font-mono};
    font-size: 11px;
    letter-spacing: 0.05em;
    color: ${text2};
}

QFrame#captureCardThumbnailSurface[thumbnailState="failed"] QLabel[labelRole="captureCardThumbnailState"],
QFrame#captureCardThumbnailSurface[thumbnailState="unavailable"] QLabel[labelRole="captureCardThumbnailState"] {
    color: ${warn};
}

QLabel[labelRole="captureCardHelp"] {
    font-size: 11px;
    color: ${text2};
}

QWidget#captureTargetCard[captureCardState="minimized"] QLabel[labelRole="captureCardHelp"],
QWidget#captureTargetCard[captureCardState="too-small"] QLabel[labelRole="captureCardHelp"],
QWidget#captureTargetCard[captureCardState="unavailable"] QLabel[labelRole="captureCardHelp"] {
    color: ${warn};
}

QLabel[labelRole="captureCardTitle"] {
    font-size: 14px;
    font-weight: 600;
    color: ${text0};
}

QLabel[labelRole="captureCardSelectedChip"] {
    font-family: ${font-mono};
    font-size: 10px;
    letter-spacing: 0.08em;
    color: ${bg0};
    border: 1px solid ${accent};
    border-radius: ${radius-sm}px;
    padding: 1px 6px;
    background: ${accent};
}

QLabel[labelRole="captureCardStatus"] {
    font-family: ${font-mono};
    font-size: 10.5px;
    letter-spacing: 0.06em;
    color: ${text2};
    border: 1px solid ${line2};
    border-radius: ${radius-sm}px;
    padding: 2px 6px;
    background: transparent;
}

QWidget#captureTargetCard[selected="true"] QLabel[labelRole="captureCardStatus"] {
    color: ${accent};
    border-color: rgba(233, 179, 97, 0.72);
    background: rgba(233, 179, 97, 0.18);
}

QWidget#captureTargetCard[captureCardTone="warning"] QLabel[labelRole="captureCardStatus"] {
    color: ${warn};
    border-color: ${warn};
    background: rgba(194, 150, 83, 0.2);
}

QWidget#captureTargetCard[captureCardState="too-small"] QLabel[labelRole="captureCardStatus"],
QWidget#captureTargetCard[captureCardState="minimized"] QLabel[labelRole="captureCardStatus"],
QWidget#captureTargetCard[captureCardState="unavailable"] QLabel[labelRole="captureCardStatus"] {
    color: ${warn};
    border-color: rgba(194, 150, 83, 0.68);
    background: rgba(194, 150, 83, 0.22);
}

QLabel[labelRole="captureCardSubtitle"] {
    font-family: ${font-mono};
    font-size: 11.5px;
    letter-spacing: 0.02em;
    color: ${text2};
}

QLabel[labelRole="captureTargetPickerLabel"] {
    font-family: ${font-mono};
    font-size: 11px;
    letter-spacing: 0.1em;
    color: ${text2};
    min-width: 70px;
}

QLabel[labelRole="captureTargetPickerNote"] {
    font-size: 11.5px;
    color: ${text2};
}

/* Video page */
QWidget#videoEffectiveRail {
    background: ${bg2};
    border-left: 1px solid ${line1};
}

QLabel[labelRole="videoFpsValue"] {
    font-family: ${font-mono};
    font-size: 48px;
    font-weight: 500;
    color: ${text0};
    letter-spacing: 0.08em;
}

QLabel[labelRole="videoFpsUnit"] {
    font-size: 18px;
    color: ${text2};
}

QLabel[labelRole="videoFpsNote"] {
    font-size: 12px;
    color: ${text2};
}

QLabel[labelRole="videoFramePill"] {
    font-family: ${font-mono};
    font-size: 10.5px;
    letter-spacing: 0.12em;
    color: ${text1};
    border: 1px solid ${line2};
    border-radius: ${radius-sm}px;
    background: ${bg3};
    padding: 4px 10px;
}

QLabel[labelRole="videoResolutionValue"] {
    font-family: ${font-mono};
    font-size: 11.5px;
    letter-spacing: 0.04em;
    color: ${text2};
}

QLabel[labelRole="videoQualityDetail"] {
    font-family: ${font-mono};
    font-size: 11px;
    letter-spacing: 0.04em;
    color: ${text2};
}

QLabel[labelRole="videoRailHead"] {
    font-family: ${font-mono};
    font-size: 11px;
    letter-spacing: 0.14em;
    color: ${text2};
}

QLabel[labelRole="videoRailUnsaved"] {
    font-family: ${font-mono};
    font-size: 10.5px;
    letter-spacing: 0.08em;
    color: ${warn};
}

QLabel[labelRole="videoKvKey"] {
    font-family: ${font-mono};
    font-size: 11px;
    color: ${text2};
    letter-spacing: 0.04em;
}

QLabel[labelRole="videoKvValue"] {
    font-family: ${font-mono};
