QLabel[labelRole="codecCardTag"] {
    font-family: ${font-mono};
    font-size: 10.5px;
    letter-spacing: 0.06em;
    color: ${text2};
    border: 1px solid ${line2};
    border-radius: ${radius-sm}px;
    padding: 2px 6px;
    background: transparent;
}

QWidget#codecCard[selected="true"] QLabel[labelRole="codecCardTag"] {
    color: ${accent};
    border-color: ${accent};
    background: rgba(215, 167, 68, 0.10);
}

QLabel[labelRole="codecCardDesc"] {
    font-size: 12px;
    color: ${text2};
}

QWidget#readinessRow {
    background: transparent;
    border-top: 1px solid ${line1};
}

QWidget#readinessRow[firstRow="true"] {
    border-top: none;
}

QLabel[labelRole="readinessGlyph"] {
    font-family: ${font-mono};
    font-size: 14px;
    color: ${text2};
}

QLabel[labelRole="readinessGlyph"][stateRole="ready"] {
    color: ${ok};
}

QLabel[labelRole="readinessGlyph"][stateRole="blocked"] {
    color: ${err};
}

QLabel[labelRole="readinessTitle"] {
    font-size: 13.5px;
    color: ${text0};
}

QLabel[labelRole="readinessDetail"] {
    font-family: ${font-mono};
    font-size: 11px;
    letter-spacing: 0.04em;
    color: ${text2};
}

QLabel[labelRole="readinessSummary"] {
    font-size: 12.5px;
