// Generated from exosnap_version.rc.in by CMake configure_file (@ONLY).
// Do not edit the generated copy in the build tree; edit the .in template.
// All version fields derive from the canonical root project(... VERSION ...).
#include <winver.h>

VS_VERSION_INFO VERSIONINFO
 FILEVERSION    @EXOSNAP_VERSION_COMMA@
 PRODUCTVERSION @EXOSNAP_VERSION_COMMA@
 FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
 FILEFLAGS      0x0L
 FILEOS         VOS_NT_WINDOWS32
 FILETYPE       VFT_APP
 FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "Exoridus"
            VALUE "FileDescription",  "ExoSnap"
            VALUE "FileVersion",      "@EXOSNAP_VERSION_FILE_STR@"
            VALUE "InternalName",     "exosnap"
            VALUE "LegalCopyright",   "Copyright (C) 2025 ExoSnap Contributors. Licensed under GPL-3.0-or-later."
            VALUE "OriginalFilename", "exosnap.exe"
            VALUE "ProductName",      "ExoSnap"
            VALUE "ProductVersion",   "@EXOSNAP_VERSION@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        // 0x0409 = U.S. English, 1200 = Unicode (UTF-16) codepage.
        VALUE "Translation", 0x409, 1200
    END
END
